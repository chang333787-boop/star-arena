 "_notes": {
  "포탈_규약": "포탈 도착 칸은 상대 포탈 앵커 '앞'의 통행 칸(도착 즉시 재워프 방지). 역방향 포탈은 전 짝 존재.",
  "스폰_규약": "monsters[]는 상시 리스폰 배치. 퀘스트 스폰(mq02 밭 습격·mq05 간부 보슬보슬·mq06 방어 웨이브)은 퀘스트 엔진 소관이라 도면에 없음.",
  "NPC_규약": "N 칸은 통행 가능으로 정의(런타임엔 NPC가 점유·충돌 처리). 배치 좌표는 map이 단일 출처(§7.1 — npc 테이블에 좌표 없음).",
  "rpg_village": "확장 밭 8×5=40칸 예정지 = (3,10)~(10,14), 기존 12칸 포함(mq06 후 200G 구매 시 f로 전환). E 빈 부지 2곳=(21~24,12~13)·(29~31,3~4). V=별광맥(mq06 방어전 무대), G=게시판, W=우물(부활).",
  "rpg_home": "D=잠긴 지하실 문(여백②). 화덕은 챕터2라 미배치.",
  "rpg_field1": "t=mq05 야영지. 초급 몬스터 8스폰(젤리3·뿔깡총2·씨앗총사2·가시딱지1).",
  "rpg_field2": "B 구역=먹구름 요새 외벽(접경), '2'=요새 정문. 개울 다리는 (20~21,10~11). 중급 7스폰(부슬이3·부엉이2·그늘조각2).",
  "rpg_den2": "c=훔친 별빛 상자(수집방 연출).",
  "rpg_den3": "e=알(여백①). 보스 뭉게대왕 단독(isBoss — 버짓 면제·교사 검수)."
 },
